NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

DATABASE_URL=DATABASE_URL=mongodb+srv://assetflow:<db_password>@cluster0.vyzjcgn.mongodb.net/?appName=Cluster0
# Local alternative (needs a replica set — see README): mongodb://localhost:27017/assetflow?replicaSet=rs0

JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=10

CORS_ORIGIN=http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=changeme
SMTP_FROM=AssetFlow <no-reply@assetflow.com>

RESET_PASSWORD_TOKEN_EXPIRES_MIN=30
